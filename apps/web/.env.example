# Copy to .env in apps/web before running `npm run dev` (or building).
# Only VITE_-prefixed vars are exposed to the browser bundle.
# These are PUBLIC values (shipped in the JS bundle). Never put secrets here.

# Base URL where the browser reaches the backend API (apps/server)
VITE_API_URL=http://localhost:3003

# ImageKit public key for client-side uploads
VITE_IMAGEKIT_PUBLIC_KEY=
