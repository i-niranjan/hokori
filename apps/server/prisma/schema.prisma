generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String    @id @default(uuid())
  userName  String    @unique
  email     String    @unique
  firstName String
  lastName  String
  password  String
  Project    Project[]
  Skill      Skill[]
  Profile    Profile?
  Page       Page?
  SocialLink SocialLink[]
}

model SocialLink {
  id       String @id @default(cuid())
  userId   String
  platform String
  url      String
  order    Int    @default(0)
  user     User   @relation(fields: [userId], references: [id])

  @@unique([userId, platform])
}

model Page {
  id        String   @id @default(cuid())
  userId    String   @unique
  theme     String   @default("minimal")
  published Boolean  @default(false)
  blocks    Json
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
}

model Project {
  id              String  @id @default(cuid())
  title           String
  desc            String
  longDesc        String?
  link            String?
  thumbnail       String?
  thumbnailFileId String?
  userId          String
  user            User    @relation(fields: [userId], references: [id])
}

model Skill {
  id     String  @id @default(cuid())
  name   String
  icon   String?
  userId String
  user   User    @relation(fields: [userId], references: [id])
}

model Profile {
  id           String  @id @default(cuid())
  userId       String  @unique
  name         String
  avatarUrl    String
  avatarFileId String
  title        String
  bio          String
  instagram    String?
  github       String?
  twitter      String?
  linkedin     String?
  user         User    @relation(fields: [userId], references: [id])
}
