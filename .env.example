# Copy to .env at the repo root before running `docker compose up`.

# Postgres (the db service creates user/db "hokori" with this password)
POSTGRES_PASSWORD=change-me

# JWT secrets — generate with: openssl rand -base64 32
ACCESS_SECRET=
REFRESH_SECRET=

# Where the web app is served from (used for CORS)
CLIENT_URL=http://localhost:8080

# Where the browser reaches the API (baked into the web build)
VITE_API_URL=http://localhost:3003

# ImageKit
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your-id
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=

# Gemini API key — powers the AI helpers (rephrase, generate, résumé import)
GEMINI_API_KEY=

# SMTP (optional — mailer is skipped when unset)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
